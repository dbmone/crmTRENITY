# ==================== DATABASE ====================
DB_PASSWORD=change_me_in_production

# ==================== TELEGRAM BOT ====================
BOT_TOKEN=token_from_@BotFather
BOT_USERNAME=your_bot_username_without_@
TELEGRAM_PROXY_URL=
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org
TELEGRAM_STORAGE_CHAT_ID=-100xxxxxxxxxxxx
USE_TELEGRAM_STORAGE=true
ADMIN_TG_USERNAME=your_username

# ==================== TELEGRAM USERBOT ====================
# Get api_id/api_hash at https://my.telegram.org
# SESSION is a StringSession from your personal Telegram account
TELEGRAM_USERBOT_API_ID=
TELEGRAM_USERBOT_API_HASH=
TELEGRAM_USERBOT_SESSION=
TELEGRAM_USERBOT_PHONE=

# ==================== JWT ====================
JWT_SECRET=generate_a_long_random_secret

# ==================== SERVER ====================
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
FRONTEND_URL=https://trenitycrm.duckdns.org/
