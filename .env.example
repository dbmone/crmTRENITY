# ==================== БАЗА ДАННЫХ ====================
# Пароль для PostgreSQL (используется в docker-compose)
DB_PASSWORD=смени_это_в_продакшне

# ==================== TELEGRAM BOT ====================
BOT_TOKEN=токен_от_@BotFather

# ID приватного канала для хранения файлов (бот должен быть admin)
# Как получить: добавь бота в канал, перешли сообщение из канала @userinfobot
TELEGRAM_STORAGE_CHAT_ID=-100xxxxxxxxxxxx

# Включить Telegram как хранилище файлов (рекомендуется)
USE_TELEGRAM_STORAGE=true

# TG username первого администратора (без @)
ADMIN_TG_USERNAME=твой_username

# ==================== JWT ====================
JWT_SECRET=сгенерируй_длинную_случайную_строку

# ==================== СЕРВЕР ====================
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# URL фронтенда (для CORS) — IP или домен твоего VPS
FRONTEND_URL=http://168.222.140.71
