generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ПОЛЬЗОВАТЕЛИ ====================

enum UserRole {
  ADMIN              // Полный доступ, может всё
  HEAD_MARKETER      // Главный маркетолог — может назначать маркетологов
  MARKETER           // Маркетолог — создаёт заказы
  HEAD_CREATOR       // Главный креатор — выше тимлида, управляет всеми командами
  HEAD_LEAD_CREATOR  // Главный тим лид — между HEAD_CREATOR и LEAD_CREATOR
  LEAD_CREATOR       // Тимлид креаторов — управляет своей командой
  CREATOR            // Креатор — выполняет заказы
}

enum UserStatus {
  PENDING         // Заявка на рассмотрении
  APPROVED        // Одобрен
  REJECTED        // Отклонён
  BLOCKED         // Заблокирован
}

model User {
  id               String     @id @default(uuid())
  telegramId       BigInt     @unique @map("telegram_id")
  telegramUsername  String?    @map("telegram_username")
  displayName      String     @map("display_name")
  avatarUrl        String?    @map("avatar_url")
  role             UserRole   @default(CREATOR)
  status           UserStatus @default(PENDING)
  pinCode          String?    @unique @map("pin_code") @db.VarChar(4)
  chatId           BigInt?    @map("chat_id")
  teamLeadId       String?    @map("team_lead_id")
  isActive         Boolean    @default(true) @map("is_active")
  guideSeenAt      DateTime?  @map("guide_seen_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  // Иерархия: тимлид → подчинённые
  teamLead         User?            @relation("TeamHierarchy", fields: [teamLeadId], references: [id])
  subordinates     User[]           @relation("TeamHierarchy")

  createdOrders    Order[]          @relation("OrderMarketer")
  assignments      OrderCreator[]   @relation("CreatorAssignments")
  addedCreators    OrderCreator[]   @relation("AddedByUser")
  uploadedFiles    OrderFile[]
  dailyReports     DailyReport[]
  notifications    Notification[]
  comments         OrderComment[]
  userPermissions  UserPermission[]
  approvedById     String?          @map("approved_by_id")
  tasks            Task[]
  creatorResults   OrderCreatorResult[] @relation("CreatorResults")
  resultsSetBy     OrderCreatorResult[] @relation("ResultsSetBy")
  helpedStoryboard OrderCreatorResult[] @relation("HelperStoryboard")
  helpedAnimation  OrderCreatorResult[] @relation("HelperAnimation")
  helpedEditing    OrderCreatorResult[] @relation("HelperEditing")
  helpedScenario   OrderCreatorResult[] @relation("HelperScenario")

  @@map("users")
}

// ==================== ЗАКАЗЫ ====================

enum OrderStatus {
  NEW
  IN_PROGRESS
  ON_REVIEW
  DONE
  ARCHIVED
}

model Order {
  id            String      @id @default(uuid())
  title         String      @db.VarChar(255)
  description   String?     @db.Text
  status        OrderStatus @default(NEW)
  deadline      DateTime?
  reminderDays  Int         @default(2) @map("reminder_days")
  marketerId    String      @map("marketer_id")
  telegramGroupChatId    BigInt?   @map("telegram_group_chat_id")
  telegramGroupTitle     String?   @map("telegram_group_title")
  telegramGroupInviteLink String?  @map("telegram_group_invite_link")
  telegramGroupCreatedAt DateTime? @map("telegram_group_created_at")
  price         Float?      // стоимость заказа
  hasTax        Boolean     @default(false) @map("has_tax") // НДС +6%
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  marketer      User             @relation("OrderMarketer", fields: [marketerId], references: [id])
  creators      OrderCreator[]
  files         OrderFile[]
  stages        OrderStage[]
  reports       DailyReport[]
  notifications Notification[]
  comments      OrderComment[]
  creatorResults OrderCreatorResult[]

  @@map("orders")
}

// ==================== КРЕАТОРЫ НА ЗАКАЗЕ ====================

model OrderCreator {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  creatorId  String   @map("creator_id")
  addedById  String   @map("added_by_id")
  isLead     Boolean  @default(false) @map("is_lead")
  assignedAt DateTime @default(now()) @map("assigned_at")

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  creator User  @relation("CreatorAssignments", fields: [creatorId], references: [id])
  addedBy User  @relation("AddedByUser", fields: [addedById], references: [id])

  @@unique([orderId, creatorId])
  @@map("order_creators")
}

// ==================== РЕЗУЛЬТАТЫ КРЕАТОРОВ (галочки) ====================

model OrderCreatorResult {
  id                   String    @id @default(uuid())
  orderId              String    @map("order_id")
  creatorId            String    @map("creator_id")
  // Что сделал сам
  didStoryboard        Boolean   @default(false) @map("did_storyboard")
  didAnimation         Boolean   @default(false) @map("did_animation")
  didEditing           Boolean   @default(false) @map("did_editing")
  didScenario          Boolean   @default(false) @map("did_scenario")
  // Кто помог (если галочка не стоит)
  helperStoryboardId   String?   @map("helper_storyboard_id")
  helperAnimationId    String?   @map("helper_animation_id")
  helperEditingId      String?   @map("helper_editing_id")
  helperScenarioId     String?   @map("helper_scenario_id")
  setByUserId          String?   @map("set_by_id")
  setAt                DateTime? @map("set_at")

  order               Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  creator             User  @relation("CreatorResults", fields: [creatorId], references: [id])
  setBy               User? @relation("ResultsSetBy", fields: [setByUserId], references: [id])
  helperStoryboard    User? @relation("HelperStoryboard", fields: [helperStoryboardId], references: [id])
  helperAnimation     User? @relation("HelperAnimation", fields: [helperAnimationId], references: [id])
  helperEditing       User? @relation("HelperEditing", fields: [helperEditingId], references: [id])
  helperScenario      User? @relation("HelperScenario", fields: [helperScenarioId], references: [id])

  @@unique([orderId, creatorId])
  @@map("order_creator_results")
}

// ==================== ЭТАПЫ ЗАКАЗА ====================

enum StageName {
  STORYBOARD
  ANIMATION
  EDITING
  REVIEW
  COMPLETED
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model OrderStage {
  id                     String      @id @default(uuid())
  orderId                String      @map("order_id")
  name                   StageName
  status                 StageStatus @default(PENDING)
  startedAt              DateTime?   @map("started_at")
  completedAt            DateTime?   @map("completed_at")
  sortOrder              Int         @map("sort_order")
  revisionRound          Int         @default(0) @map("revision_round")
  // Sub-stage: "ожидание апрува от клиента" (for STORYBOARD and ANIMATION)
  awaitingClientApproval Boolean     @default(false) @map("awaiting_client_approval")
  clientApprovalSkipped  Boolean     @default(false) @map("client_approval_skipped")
  clientApprovedAt       DateTime?   @map("client_approved_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, name, revisionRound])
  @@map("order_stages")
}

// ==================== ФАЙЛЫ ====================

enum FileType {
  TZ
  CONTRACT
  STORYBOARD
  VIDEO_DRAFT
  VIDEO_FINAL
  OTHER
}

model OrderFile {
  id              String   @id @default(uuid())
  orderId         String   @map("order_id")
  uploadedById    String   @map("uploaded_by_id")
  fileType        FileType @map("file_type")
  fileName        String   @map("file_name")
  fileSize        BigInt   @map("file_size")
  mimeType        String   @map("mime_type")
  storagePath     String   @default("") @map("storage_path")  // "" для TG-файлов
  // Telegram storage (альтернатива S3)
  telegramFileId  String?  @map("telegram_file_id")
  telegramChatId  String?  @map("telegram_chat_id")
  telegramMsgId   Int?     @map("telegram_msg_id")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@map("order_files")
}

// ==================== ЕЖЕДНЕВНЫЕ ОТЧЁТЫ ====================

model DailyReport {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  creatorId   String   @map("creator_id")
  reportText  String   @map("report_text") @db.Text
  reportDate  DateTime @map("report_date") @db.Date
  submittedAt DateTime @default(now()) @map("submitted_at")

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  creator User  @relation(fields: [creatorId], references: [id])

  @@unique([orderId, creatorId, reportDate])
  @@map("daily_reports")
}

// ==================== КОММЕНТАРИИ ====================

model OrderComment {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  authorId  String   @map("author_id")
  text      String   @db.Text
  source    String   @default("WEB") @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])

  @@map("order_comments")
}

// ==================== УВЕДОМЛЕНИЯ ====================

enum NotificationType {
  NEW_ORDER
  ASSIGNED
  STAGE_CHANGED
  DEADLINE_WARNING
  REPORT_REMINDER
  REVIEW_REQUEST
  ORDER_APPROVED
  COMMENT_ADDED
  REGISTRATION_REQUEST
  REGISTRATION_APPROVED
  REGISTRATION_REJECTED
  CHECKBOXES_REQUIRED    // запрос на проставление галочек по итогу заказа
  CHECKBOXES_SET         // галочки выставлены
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  orderId   String?          @map("order_id")
  type      NotificationType
  message   String           @db.Text
  isSent    Boolean          @default(false) @map("is_sent")
  isRead    Boolean          @default(false) @map("is_read")
  sentAt    DateTime?        @map("sent_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@map("notifications")
}

// ==================== ЛИЧНЫЕ ЗАДАЧИ ====================

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  title       String       @db.VarChar(500)
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  aiGenerated Boolean      @default(false) @map("ai_generated")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtasks TaskSubtask[]

  @@map("tasks")
}

model TaskSubtask {
  id        String  @id @default(uuid())
  taskId    String  @map("task_id")
  title     String  @db.VarChar(500)
  done      Boolean @default(false)
  sortOrder Int     @default(0) @map("sort_order")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_subtasks")
}

// ==================== НАСТРОЙКИ ПРИЛОЖЕНИЯ ====================

model AppSetting {
  key         String   @id
  value       String   @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")

  @@map("app_settings")
}

// ==================== ПРАВА ДОСТУПА ====================

model Permission {
  id        String     @id @default(cuid())
  key       String     @unique
  label     String
  roles     UserRole[]
  updatedAt DateTime   @updatedAt

  @@map("permissions")
}

model UserPermission {
  id         String  @id @default(cuid())
  userId     String  @map("user_id")
  permission String
  granted    Boolean
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@map("user_permissions")
}
